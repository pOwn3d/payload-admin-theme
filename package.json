{
  "name": "@consilioweb/payload-admin-theme",
  "version": "0.2.0",
  "description": "Payload CMS plugin — customize admin panel appearance with theming, branding, and CSS variables",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    "./rsc": {
      "import": {
        "types": "./dist/rsc.d.ts",
        "default": "./dist/rsc.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "payload",
    "payload-cms",
    "payload-plugin",
    "admin-theme",
    "theming",
    "branding",
    "css-variables",
    "customization",
    "nextjs",
    "react",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pOwn3d/payload-admin-theme.git"
  },
  "homepage": "https://github.com/pOwn3d/payload-admin-theme#readme",
  "bugs": {
    "url": "https://github.com/pOwn3d/payload-admin-theme/issues"
  },
  "author": "ConsilioWEB <contact@consilioweb.fr> (https://consilioweb.fr)",
  "license": "MIT",
  "peerDependencies": {
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/translations": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "next": "^14.0.0 || ^15.0.0",
    "payload": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@payloadcms/ui": {
      "optional": true
    },
    "@payloadcms/translations": {
      "optional": true
    },
    "@payloadcms/next": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@payloadcms/translations": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "payload": "^3.79.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
